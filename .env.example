# ==========================================
# PAICS - Variáveis de Ambiente
# ==========================================
# Renomeie este arquivo para .env e preencha com seus valores

# --- REQUERIDAS ---

# Chave da API do Google Gemini
# Obtenha sua chave em: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=sua_chave_aqui

# Chave secreta para assinar tokens JWT (gerada automaticamente se não fornecida)
# Em produção, use uma chave forte e segura (ex: secrets.token_urlsafe(32))
JWT_SECRET_KEY=

# --- MongoDB (obrigatório em produção; opcional em dev com Docker/local) ---
# Local/Docker: mongodb://localhost:27017/
# MongoDB Atlas (gratuito): use a Connection String do cluster (ex.: mongodb+srv://user:pass@cluster.mongodb.net/)
MONGO_URI=mongodb://localhost:27017/
# Nome do banco de dados (Atlas cria automaticamente se não existir)
MONGO_DB_NAME=paics_db

# --- OPCIONAIS (Valores padrão mostrados) ---

# Modelo da IA Gemini a ser utilizado
# Opções: gemini-1.5-pro-latest, gemini-1.5-flash, gemini-2.0-flash-exp, etc.
GEMINI_MODEL_NAME=gemini-2.5-pro

# Diretório onde os laudos serão salvos (linha de comando)
OUTPUT_DIR=laudos_com_ia

# Diretório temporário usado pelo Streamlit
STREAMLIT_TEMP_DIR=temp_laudos

# Fator de zoom para processamento de PDF (padrão: 2.0)
# Valores maiores = melhor qualidade, mas arquivos maiores
PDF_ZOOM_FACTOR=2.0

# Largura das imagens no documento Word (em polegadas)
IMAGE_WIDTH_INCHES=5.5

# Fonte do documento Word (padrão: Calibri)
DOC_FONT_NAME=Calibri

# Tamanho da fonte do documento Word (padrão: 11)
DOC_FONT_SIZE=11

# Idiomas para o Tesseract (OCR)
# Exemplo: 'por' para português, 'eng' para inglês, 'por+eng' para ambos
TESSERACT_LANG=por+eng

# ==========================================
# Sistema de Aprendizado Contínuo
# ==========================================

# Habilitar uso de modelo local (Ollama, LlamaCPP, etc.)
# Valores: true, false
USE_LOCAL_MODEL=false

# Tipo de modelo local a usar
# Opções: ollama, llamacpp
LOCAL_MODEL_TYPE=ollama

# Nome do modelo local (ex: llama3.2, mistral, etc.)
OLLAMA_MODEL_NAME=llama3.2

# URL base do servidor Ollama
OLLAMA_BASE_URL=http://localhost:11434

# URL base do servidor LlamaCPP (se usar)
LLAMACPP_BASE_URL=http://localhost:8080
LLAMACPP_MODEL_NAME=llama

# Threshold de similaridade para usar apenas modelo local (0.0 a 1.0)
# Valores mais altos = mais conservador (exige maior similaridade)
SIMILARITY_THRESHOLD=0.75

# Rating mínimo dos casos similares para usar modelo local (1 a 5)
# Valores mais altos = apenas casos muito bem avaliados
MIN_RATING_FOR_LOCAL=3

# Usar API externa como fallback se modelo local falhar
# Valores: true, false
USE_EXTERNAL_FALLBACK=true
